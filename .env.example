# Copy to .env.local and fill with your Supabase project (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Use either the legacy anon JWT or the new publishable key (not both required).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: host “Fetch CricAPI & score” on Fantasy league (server-side only; add in Vercel Production).
CRICAPI_KEY=

# Vercel Cron (optional): server-side sync for active fantasy leagues.
# The cron endpoint reads today's CricAPI match IDs from CRICAPI_DAILY_MATCH_IDS.
CRON_SECRET=
CRICAPI_DAILY_MATCH_IDS=
CRICAPI_DAILY_MATCH_DATE=
# Cron auto-discovery: require this phrase in match name (default in code: indian premier league).
# If you add `ipl`, it is matched as whole word only (not inside e.g. "multiple").
CRICAPI_IPL_SERIES_SUBSTRINGS=
# Optional extra gate on team names when series string matches many leagues.
CRICAPI_IPL_TEAM_SUBSTRINGS=
